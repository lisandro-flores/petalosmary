---
import Layout from '../layouts/Layout.astro';
import NavbarMinimal from '../components/NavbarMinimal.astro';
import HeroMinimal from '../components/HeroMinimal.astro';
import GalleryMinimal from '../components/GalleryMinimal.astro';
import ValueProps from '../components/ValueProps.astro';
import ProcessMinimal from '../components/ProcessMinimal.astro';
import Testimonials from '../components/Testimonials.astro';
import Faq from '../components/Faq.astro';
import ContactMinimal from '../components/ContactMinimal.astro';
import FooterMinimal from '../components/FooterMinimal.astro';
import FullGallery from '../components/FullGallery.astro';
import SeasonalBanner from '../components/SeasonalBanner.astro';
---

<Layout
  title="Pétalos Mary — Florería"
  description="Arreglos florales para fechas especiales en San José Buenavista, Puebla. Atención personalizada."
>
  <SeasonalBanner />
  <NavbarMinimal />
  <main>
    <HeroMinimal />
    <GalleryMinimal />
    <ValueProps />
    <ProcessMinimal />
    <Testimonials />
    <Faq />
    <ContactMinimal />
  </main>
  <FooterMinimal />
  
  <FullGallery />

  <!-- Floating WhatsApp Button -->
  <a 
    href="https://wa.me/5212371113802?text=Hola%2C%20quiero%20cotizar%20un%20arreglo%20floral" 
    class="floating-wa"
    target="_blank"
    rel="noreferrer"
    aria-label="Contactar por WhatsApp"
    id="floatingWa"
  >
    <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
    <span class="floating-wa__tooltip">¿Te ayudamos?</span>
  </a>
</Layout>

<style is:global>
  /* Floating WhatsApp Button */
  .floating-wa {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 90;
    width: 60px;
    height: 60px;
    background: linear-gradient(135deg, #25d366, #128c7e);
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 6px 20px rgba(37, 211, 102, 0.35), 0 2px 8px rgba(0,0,0,0.1);
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.3s ease;
    text-decoration: none;
    animation: waAppear 0.6s ease-out 2s both;
  }

  .floating-wa:hover {
    transform: scale(1.1) translateY(-3px);
    box-shadow: 0 10px 28px rgba(37, 211, 102, 0.45), 0 4px 12px rgba(0,0,0,0.12);
  }

  .floating-wa::before {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    background: rgba(37, 211, 102, 0.2);
    animation: waPulse 3s ease-in-out infinite;
    z-index: -1;
  }

  .floating-wa__tooltip {
    position: absolute;
    right: calc(100% + 12px);
    top: 50%;
    transform: translateY(-50%);
    background: #fff;
    color: #1c191a;
    padding: 0.5rem 1rem;
    border-radius: 8px;
    font-size: 0.8rem;
    font-weight: 600;
    white-space: nowrap;
    box-shadow: 0 4px 16px rgba(0,0,0,0.1);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.25s ease, visibility 0.25s ease;
    pointer-events: none;
  }

  .floating-wa__tooltip::after {
    content: '';
    position: absolute;
    left: 100%;
    top: 50%;
    transform: translateY(-50%);
    border: 5px solid transparent;
    border-left-color: #fff;
  }

  .floating-wa:hover .floating-wa__tooltip {
    opacity: 1;
    visibility: visible;
  }

  @keyframes waPulse {
    0%, 100% { transform: scale(1); opacity: 0.5; }
    50%      { transform: scale(1.3); opacity: 0; }
  }

  @keyframes waAppear {
    from { opacity: 0; transform: scale(0.5) translateY(20px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
  }

  @media (max-width: 480px) {
    .floating-wa {
      width: 54px;
      height: 54px;
      bottom: 1rem;
      right: 1rem;
    }

    .floating-wa__tooltip {
      display: none;
    }
  }
</style>
