---
// Muestra un mensaje breve según la época del año para destacar promociones puntuales.
// El contenido está duro por simplicidad, se puede convertir a CMS o variables más adelante.

const now = new Date();
const month = now.getMonth() + 1; // 1-12
const day   = now.getDate();

let message = '';

// Día de las Madres (10 de mayo)
if ((month === 3 && day >= 22) || month === 4 || (month === 5 && day <= 10)) {
  message = 'El próximo festivo es el 10 de mayo: agenda tu arreglo para el Día de las Madres con entrega especial en Puebla.';
}

// San Valentín (14 febrero)
if (month === 2 && day >= 7 && day <= 15) {
  message = 'San Valentín: ramos para enamorar, pide con anticipación.';
}

---

{message && (
  <div class="seasonal-banner" id="seasonalBanner" aria-live="polite">
    {message}
  </div>
)}

<script>
  const banner = document.getElementById('seasonalBanner');
  if (banner) {
    setTimeout(() => {
      banner.style.opacity = '0';
      banner.style.visibility = 'hidden';
      setTimeout(() => {
        banner.style.display = 'none';
      }, 500); // Esperar a que termine la transición de opacidad
    }, 5000);
  }
</script>

<style>
  .seasonal-banner {
    position: sticky;
    top: 0;
    left: 0;
    right: 0;
    background: var(--color-primary);
    color: #fff;
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1.4;
    text-align: center;
    padding: 0.55rem 3rem;
    z-index: 200;
    box-shadow: 0 2px 8px rgba(0,0,0,.18);
    letter-spacing: 0.01em;
    animation: bannerPulse 3s infinite ease-in-out;
    transition: opacity 0.5s ease-out, visibility 0.5s ease-out;
  }

  @keyframes bannerPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.7; }
  }
</style>