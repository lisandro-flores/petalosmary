---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <span class="footer__logo">Pétalos Mary</span>
      <p class="footer__tagline">Florista artesanal en Puebla</p>
    </div>

    <nav class="footer__nav" aria-label="Enlaces de navegación">
      <a href="#inicio">Inicio</a>
      <a href="#galeria">Galería</a>
      <a href="https://wa.me/5212371113802" target="_blank" rel="noreferrer">WhatsApp</a>
    </nav>

    <p class="footer__copy">© {year} Pétalos Mary</p>
  </div>
</footer>

<style>
  .footer {
    padding: 3rem 0 2rem;
    background: var(--color-text);
    color: #fff;
  }

  .footer__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
  }

  .footer__logo {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
  }

  .footer__tagline {
    font-size: 0.875rem;
    opacity: 0.7;
    margin: 0.25rem 0 0;
  }

  .footer__nav {
    display: flex;
    gap: 2rem;
  }

  .footer__nav a {
    color: #fff;
    opacity: 0.7;
    font-size: 0.875rem;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .footer__nav a:hover {
    opacity: 1;
  }

  .footer__copy {
    font-size: 0.8125rem;
    opacity: 0.5;
    margin: 0;
  }
</style>
