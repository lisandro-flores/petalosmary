---
import { FALLBACK_SPRING } from '../lib/fallback';
import type { SpringPhoto } from '../lib/fallback';

interface Props { amarillas?: SpringPhoto[]; }
const { amarillas = FALLBACK_SPRING } = Astro.props;

// Mostrar solo 4 imágenes principales
const displayPhotos = amarillas.slice(0, 4);
---

<section class="yellow" id="inicio">
  <div class="container">
    <header class="yellow__header">
      <span class="yellow__badge">10 de Mayo</span>
      <h1 class="yellow__title">Flores Amarillas</h1>
      <p class="yellow__subtitle">
        Celebra el Día de las Madres con un arreglo especial.
        Amor, gratitud y ternura en cada pétalo.
      </p>
    </header>

    <div class="yellow__grid">
      {displayPhotos.map((img, idx) => (
        <a
          href={`https://wa.me/5212371113802?text=Hola%2C%20me%20interesa%20este%20arreglo%20amarillo:%20${encodeURIComponent(img.alt)}`}
          class="yellow__item"
          target="_blank"
          rel="noreferrer"
        >
          <img
            src={img.src}
            alt={img.alt}
            loading={idx < 2 ? 'eager' : 'lazy'}
            decoding="async"
          />
        </a>
      ))}
    </div>

    <div class="yellow__actions">
      <a 
        href="https://wa.me/5212371113802?text=Hola%2C%20quiero%20cotizar%20un%20arreglo%20de%20flores%20amarillas" 
        class="yellow__cta"
        target="_blank"
        rel="noreferrer"
      >
        Pedir por WhatsApp
      </a>
      <button type="button" class="yellow__more open-gallery-btn">
        Ver más trabajos
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </button>
    </div>
  </div>
</section>

<style>
  .yellow {
    display: flex;
    align-items: center;
    padding: 5rem 0;
    background: linear-gradient(to bottom, #fffef5 0%, #fffbea 100%);
  }

  .yellow__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .yellow__badge {
    display: inline-block;
    background: #fef08a;
    color: #7c5800;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.5rem 1rem;
    border-radius: 999px;
    margin-bottom: 1.5rem;
  }

  .yellow__title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 700;
    color: #3d2e00;
    margin: 0 0 1rem;
    line-height: 1;
  }

  .yellow__subtitle {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: #6b5c00;
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .yellow__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-bottom: 3rem;
  }

  .yellow__item {
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: 1rem;
    background: #f5f0d0;
  }

  .yellow__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .yellow__item:hover img {
    transform: scale(1.05);
  }

  .yellow__item:focus-visible {
    outline: 3px solid #d4a000;
    outline-offset: 2px;
  }

  .yellow__actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .yellow__cta {
    background: #3d2e00;
    color: #fff;
    padding: 1rem 2rem;
    border-radius: 999px;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .yellow__cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(61, 46, 0, 0.2);
  }

  .yellow__more {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: transparent;
    border: 2px solid #3d2e00;
    color: #3d2e00;
    padding: 1rem 2rem;
    border-radius: 999px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }

  .yellow__more:hover {
    background: #3d2e00;
    color: #fff;
  }

  @media (max-width: 768px) {
    .yellow__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .yellow__actions {
      flex-direction: column;
      align-items: stretch;
    }

    .yellow__cta,
    .yellow__more {
      text-align: center;
      justify-content: center;
    }
  }
</style>
