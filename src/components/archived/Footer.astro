---
const year = new Date().getFullYear();

const links = [
  { label: 'Inicio',   href: '#inicio'   },
  { label: 'Galería',  href: '#galeria'  },
  { label: 'Contacto', href: '#contacto' },
];
---

<footer class="footer" aria-label="Pie de página">
  <div class="container footer__inner">
    <!-- Brand -->
    <div class="footer__brand">
      <a href="/" class="footer__logo" aria-label="Pétalos Mary – inicio">
        <img src="/logo.png" alt="Pétalos Mary" class="footer__logo-img" width="48" height="48" loading="lazy" />
        <span class="footer__logo-name">Pétalos <strong>Mary</strong></span>
      </a>
      <p class="footer__tagline">
        Florería artesanal para fechas especiales, con atención directa y una presencia visual más consistente.
      </p>
    </div>

    <!-- Nav -->
    <nav class="footer__nav" aria-label="Navegación del pie de página">
      <p class="footer__nav-title">Navegación</p>
      <ul class="footer__nav-list">
        {links.map(({ label, href }) => (
          <li><a href={href} class="footer__nav-link">{label}</a></li>
        ))}
      </ul>
    </nav>

    <!-- Services column -->
    <div class="footer__services">
      <p class="footer__nav-title">Servicios</p>
      <ul class="footer__nav-list">
        {['Arreglos nupciales', 'Ramos & bouquets', 'Eventos corporativos', 'Suscripción semanal', 'Regalos especiales', 'Plantas de interior'].map(s => (
          <li><a href="#galeria" class="footer__nav-link">{s}</a></li>
        ))}
      </ul>
    </div>

    <div class="footer__contact">
      <p class="footer__nav-title">Contacto</p>
      <ul class="footer__nav-list">
        <li><a href="https://wa.me/5212371113802" class="footer__nav-link" target="_blank" rel="noreferrer">WhatsApp</a></li>
        <li><a href="mailto:hola@petalosmary.com" class="footer__nav-link">hola@petalosmary.com</a></li>
        <li><span class="footer__nav-link">Sin local físico, trabajamos por pedido</span></li>
        <li><span class="footer__nav-link">Lun–Sáb · 9:00 a 19:00</span></li>
      </ul>
    </div>

  </div>

  <!-- Bottom bar -->
  <div class="footer__bar">
    <div class="container footer__bar-inner">
      <p>© {year} Pétalos Mary · Todos los derechos reservados</p>
      <p>Hecho con <span aria-label="amor" style="color:#e53e3e;display:inline-flex;align-items:center;vertical-align:middle">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="#e53e3e" stroke="#e53e3e" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      </span> desde Puebla</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-text);
    color: rgba(255,255,255,.75);
    padding-top: 4.5rem;
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1.8fr;
    gap: clamp(2rem, 4vw, 4rem);
    padding-bottom: 3.5rem;
    border-bottom: 1px solid rgba(255,255,255,.08);
  }

  /* Brand */
  .footer__logo {
    display: flex;
    align-items: center;
    gap: .65rem;
    margin-bottom: 1rem;
  }

  .footer__logo-img {
    width: 48px;
    height: 48px;
    object-fit: contain;
    border-radius: var(--radius-sm);
    flex-shrink: 0;
  }

  .footer__logo-name {
    font-family: var(--font-display);
    color: #fff;
  }

  .footer__logo-name strong { color: var(--color-accent-dark); }

  .footer__tagline {
    font-size: .875rem;
    line-height: 1.65;
    max-width: 32ch;
  }

  /* Nav */
  .footer__nav-title {
    font-size: .75rem;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: rgba(255,255,255,.45);
    margin-bottom: 1rem;
  }

  .footer__nav-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: .55rem;
  }

  .footer__nav-link {
    font-size: .875rem;
    color: rgba(255,255,255,.65);
    transition: color var(--transition);
  }

  .footer__nav-link:hover { color: #fff; }

  /* Bottom bar */
  .footer__bar { padding-block: 1.25rem; }

  .footer__bar-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    font-size: .8125rem;
    color: rgba(255,255,255,.4);
  }

  @media (max-width: 1024px) { .footer__inner { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 600px)  { .footer__inner { grid-template-columns: 1fr; } }
  @media (max-width: 480px)  { .footer__bar-inner { flex-direction: column; text-align: center; } }
</style>
