---
const navLinks = [
  { label: 'Inicio',            href: '#inicio'      },
  { label: 'Flores amarillas', href: '#primavera'   },
  { label: 'Galería',           href: '#galeria'     },
  { label: 'Contacto',          href: '#contacto'    },
];
---

<header class="navbar" id="navbar">
  <div class="container navbar__inner">
    <!-- Brand -->
    <a href="/" class="navbar__brand" aria-label="Pétalos Mary – inicio">
      <img src="/logo.png" alt="Pétalos Mary" class="navbar__logo-img" width="44" height="44" />
      <span class="navbar__brand-copy">
        <strong class="navbar__brand-title">Pétalos Mary</strong>
        <span class="navbar__brand-subtitle">Florería artesanal</span>
      </span>
    </a>

    <!-- Desktop nav -->
    <nav class="navbar__nav" aria-label="Navegación principal">
      {navLinks.map(({ label, href }) => (
        <a href={href} class="navbar__link">{label}</a>
      ))}
    </nav>

    <!-- CTA -->
    <a href="#contacto" class="btn btn-primary navbar__cta">
      Pedir por WhatsApp
    </a>

    <!-- Mobile hamburger -->
    <button class="navbar__hamburger" id="menuToggle" aria-label="Abrir menú" aria-expanded="false" aria-controls="mobileMenu">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <nav class="navbar__mobile" id="mobileMenu" aria-label="Menú móvil" hidden>
    {navLinks.map(({ label, href }) => (
      <a href={href} class="navbar__mobile-link">{label}</a>
    ))}
    <a href="#contacto" class="btn btn-primary navbar__mobile-cta">Hacer un pedido</a>
  </nav>
</header>

<style>
  .navbar {
    position: fixed;
    inset-block-start: 0;
    inset-inline: 0;
    z-index: 900;
    background: rgba(255, 250, 251, 0.7);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border-bottom: 1px solid rgba(214, 51, 132, 0.05);
    transition: all var(--transition);
  }

  .navbar.scrolled {
    background: rgba(255, 250, 251, 0.9);
    border-bottom-color: var(--color-border);
    box-shadow: var(--shadow-md);
  }

  .navbar__inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    height: 68px;
  }

  /* Brand */
  .navbar__brand {
    display: flex;
    align-items: center;
    gap: .55rem;
    flex-shrink: 0;
  }

  .navbar__brand-copy {
    display: flex;
    flex-direction: column;
    line-height: 1.05;
  }

  .navbar__brand-title {
    font-family: var(--font-display);
    font-size: .98rem;
    color: var(--color-text);
  }

  .navbar__brand-subtitle {
    font-size: .7rem;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .navbar__logo-img {
    width: 44px;
    height: 44px;
    object-fit: contain;
    border-radius: var(--radius-sm);
  }

  /* Links */
  .navbar__nav {
    display: flex;
    align-items: center;
    gap: .25rem;
    margin-inline-start: auto;
  }

  .navbar__link {
    font-size: .875rem;
    font-weight: 500;
    color: var(--color-text-muted);
    padding: .4rem .75rem;
    border-radius: var(--radius-sm);
    transition: color var(--transition), background var(--transition);
  }

  .navbar__link:hover {
    color: var(--color-primary);
    background: var(--color-accent);
  }

  /* CTA */
  .navbar__cta {
    font-size: .875rem;
    padding: .55rem 1.25rem;
    margin-inline-start: .5rem;
  }

  /* Hamburger */
  .navbar__hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    background: none;
    border: none;
    padding: 6px;
    cursor: pointer;
    margin-inline-start: auto;
    border-radius: var(--radius-sm);
    transition: background var(--transition);
  }

  .navbar__hamburger:hover { background: var(--color-accent); }

  .navbar__hamburger span {
    display: block;
    height: 2px;
    background: var(--color-text);
    border-radius: 2px;
    transition: transform var(--transition), opacity var(--transition);
  }

  .navbar__hamburger[aria-expanded="true"] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .navbar__hamburger[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .navbar__hamburger[aria-expanded="true"] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* Mobile menu */
  .navbar__mobile {
    display: flex;
    flex-direction: column;
    padding: 1rem 1.5rem 1.5rem;
    border-top: 1px solid var(--color-border);
    gap: .25rem;
    background: var(--color-bg);
  }

  .navbar__mobile[hidden] { display: none; }

  .navbar__mobile-link {
    font-size: .9375rem;
    font-weight: 500;
    color: var(--color-text-muted);
    padding: .65rem .75rem;
    border-radius: var(--radius-sm);
    transition: color var(--transition), background var(--transition);
  }

  .navbar__mobile-link:hover {
    color: var(--color-primary);
    background: var(--color-accent);
  }

  .navbar__mobile-cta {
    margin-top: .75rem;
    text-align: center;
    justify-content: center;
  }

  @media (max-width: 820px) {
    .navbar__nav,
    .navbar__cta { display: none; }
    .navbar__hamburger { display: flex; }
  }

  @media (max-width: 520px) {
    .navbar__brand-subtitle { display: none; }
    .navbar__brand-title { font-size: .9rem; }
  }
</style>

<script>
  // Scroll shadow
  const navbar = document.getElementById('navbar')!;
  const onScroll = () => navbar.classList.toggle('scrolled', window.scrollY > 20);
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Mobile toggle
  const toggle = document.getElementById('menuToggle') as HTMLButtonElement;
  const menu   = document.getElementById('mobileMenu') as HTMLElement;

  toggle.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    menu.hidden = open;
  });

  // Close on link click
  menu.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      toggle.setAttribute('aria-expanded', 'false');
      menu.hidden = true;
    });
  });
</script>
