---
import { FALLBACK_SPRING } from '../lib/fallback';
import type { SpringPhoto } from '../lib/fallback';

interface Props { amarillas?: SpringPhoto[]; }
const { amarillas = FALLBACK_SPRING } = Astro.props;

const meanings = [
  { icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#b07d00" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>`, label: 'Alegría',          desc: 'Su color irradia luz y energía positiva en cada espacio.' },
  { icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#b07d00" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`, label: 'Amor & Amistad',   desc: 'Expresa el afecto más puro y los lazos más sinceros.' },
  { icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#b07d00" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l2.9 6.1L21 9.3l-4.5 3.4L17 21l-5-2.6L7 21l.5-8.3L3 9.3l6.1-1.2L12 2z"/></svg>`, label: 'Nuevos comienzos', desc: 'Cada pétalo amarillo trae frescura y esperanza renovada.' },
  { icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#b07d00" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 17H3a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11a2 2 0 0 1 2 2v3"/><path d="M17.5 21.5c2.485 0 4.5-2.015 4.5-4.5S19.985 12.5 17.5 12.5 13 14.515 13 17s2.015 4.5 4.5 4.5z"/><path d="M17.5 14v3.5l2 1"/></svg>`, label: 'Primavera',         desc: 'Anuncian el despertar de la naturaleza en el hemisferio norte.' },
];
---

<section class="spring section" id="primavera" aria-labelledby="spring-title">
  <!-- Petals decoration -->
  <div class="spring__petals" aria-hidden="true">
    <span>✿</span><span>✾</span><span>✿</span><span>❀</span>
    <span>✿</span><span>✾</span><span>✿</span><span>❀</span>
    <span>✿</span><span>✾</span>
  </div>

  <div class="container">
    <!-- Badge -->
    <div class="spring__badge-wrap">
      <span class="spring__date-badge">
        <span class="spring__date-icon" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#b07d00" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l2.9 6.1L21 9.3l-4.5 3.4L17 21l-5-2.6L7 21l.5-8.3L3 9.3l6.1-1.2L12 2z"/></svg>
        </span>
        21 de Marzo · Día de las Flores Amarillas
      </span>
    </div>

    <!-- Header -->
    <div class="spring__header reveal">
      <span class="section-label" style="color:#b07d00">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l2.9 6.1L21 9.3l-4.5 3.4L17 21l-5-2.6L7 21l.5-8.3L3 9.3l6.1-1.2L12 2z"/></svg>
        Tradición de primavera
      </span>
      <h2 class="section-title spring__title" id="spring-title">
        El 21 de marzo, regala<br><em class="spring__em">flores amarillas</em>
      </h2>
      <p class="section-body spring__intro">
        Cada año, con el inicio de la primavera en el hemisferio norte, las flores
        amarillas simbolizan <strong>alegría, amor, amistad y nuevos comienzos</strong>.
        Haz que alguien especial lo reciba de Pétalos Mary.
      </p>
    </div>

    <!-- Countdown -->
    <div class="spring__countdown" aria-live="polite" aria-label="Cuenta regresiva al 21 de marzo">
      <div class="spring__countdown-label">Faltan</div>
      <div class="spring__countdown-units">
        <div class="spring__unit">
          <span class="spring__unit-val" id="cdDays">--</span>
          <span class="spring__unit-label">días</span>
        </div>
        <span class="spring__unit-sep" aria-hidden="true">:</span>
        <div class="spring__unit">
          <span class="spring__unit-val" id="cdHours">--</span>
          <span class="spring__unit-label">horas</span>
        </div>
        <span class="spring__unit-sep" aria-hidden="true">:</span>
        <div class="spring__unit">
          <span class="spring__unit-val" id="cdMins">--</span>
          <span class="spring__unit-label">minutos</span>
        </div>
        <span class="spring__unit-sep" aria-hidden="true">:</span>
        <div class="spring__unit">
          <span class="spring__unit-val" id="cdSecs">--</span>
          <span class="spring__unit-label">segundos</span>
        </div>
      </div>
      <div class="spring__countdown-label">para el inicio de la primavera</div>
    </div>

    <!-- Meanings -->
    <ul class="spring__meanings" role="list">
      {meanings.map(m => (
        <li class="spring__meaning">
          <span class="spring__meaning-icon" aria-hidden="true" set:html={m.icon}></span>
          <strong class="spring__meaning-label">{m.label}</strong>
          <p class="spring__meaning-desc">{m.desc}</p>
        </li>
      ))}
    </ul>

    <!-- Photo mosaic -->
    <div class="spring__mosaic" aria-label="Galería flores amarillas">
      {amarillas.map((img, i) => (
        <div class={`spring__photo spring__photo--${i}`}>
          <img
            src={img.src}
            alt={img.alt}
            loading="lazy"
            decoding="async"
            class="spring__photo-img"
          />
          <div class="spring__photo-overlay">
            <button
              class="spring__photo-cta"
              type="button"
              data-src={img.src}
              data-alt={img.alt}
              aria-label={`Cotizar ${img.alt}`}
            >
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg>
              Cotizar
            </button>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="spring__cta">
      <p class="spring__cta-text">
        ¡Reserva tu arreglo de flores amarillas para el <strong>21 de marzo</strong> antes de que se agoten!
      </p>
      <a href="#contacto" class="btn spring__btn" id="springCta">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l2.9 6.1L21 9.3l-4.5 3.4L17 21l-5-2.6L7 21l.5-8.3L3 9.3l6.1-1.2L12 2z"/></svg>
        Reservar mi arreglo amarillo
      </a>
      <p class="spring__urgency" id="springUrgency"></p>
    </div>
  </div>
</section>

<style>
  /* ── Section base ── */
  .spring {
    background: linear-gradient(160deg, #fffbea 0%, #fff8d6 40%, #fffef5 100%);
    border-top: 2px solid #f5e06a;
    border-bottom: 2px solid #f5e06a;
    position: relative;
    overflow: hidden;
  }

  /* ── Floating petals ── */
  .spring__petals {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .spring__petals span {
    position: absolute;
    font-size: clamp(1.4rem, 2.5vw, 2.2rem);
    opacity: .12;
    animation: petalFloat 7s ease-in-out infinite;
  }

  .spring__petals span:nth-child(1)  { top:  5%; left:  2%; animation-delay: 0s;   }
  .spring__petals span:nth-child(2)  { top: 12%; right: 4%; animation-delay: .8s;  }
  .spring__petals span:nth-child(3)  { top: 55%; left:  5%; animation-delay: 1.6s; }
  .spring__petals span:nth-child(4)  { top: 70%; right: 7%; animation-delay: .4s;  }
  .spring__petals span:nth-child(5)  { top: 85%; left: 20%; animation-delay: 2.2s; }
  .spring__petals span:nth-child(6)  { top: 40%; right:12%; animation-delay: 1.1s; }
  .spring__petals span:nth-child(7)  { top: 30%; left: 45%; animation-delay: 2.8s; }
  .spring__petals span:nth-child(8)  { top: 65%; left: 60%; animation-delay: .6s;  }
  .spring__petals span:nth-child(9)  { top: 20%; left: 75%; animation-delay: 1.9s; }
  .spring__petals span:nth-child(10) { top: 90%; right:30%; animation-delay: 3.2s; }

  @keyframes petalFloat {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50%       { transform: translateY(-24px) rotate(15deg); }
  }

  .spring > .container { position: relative; z-index: 1; }

  /* ── Badge ── */
  .spring__badge-wrap { text-align: center; margin-bottom: 1.5rem; }

  .spring__date-badge {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    background: #fef08a;
    color: #7c5800;
    font-size: .8125rem;
    font-weight: 700;
    letter-spacing: .06em;
    text-transform: uppercase;
    padding: .5rem 1.25rem;
    border-radius: 99px;
    border: 1.5px solid #fde047;
    box-shadow: 0 2px 12px rgba(250,204,21,.35);
  }

  .spring__date-icon { font-size: 1rem; }

  /* ── Header ── */
  .spring__header { text-align: center; margin-bottom: 2.5rem; }

  .spring__title { color: #3d2e00; }

  .spring__em {
    color: #c48f00 !important;
    font-style: italic;
  }

  .spring__intro {
    margin-inline: auto;
    margin-top: 1rem;
    color: #6b5200;
  }

  /* ── Countdown ── */
  .spring__countdown {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .75rem;
    margin-bottom: 3rem;
  }

  .spring__countdown-label {
    font-size: .8125rem;
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: #a07200;
    opacity: .75;
  }

  .spring__countdown-units {
    display: flex;
    align-items: center;
    gap: .75rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .spring__unit {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: #fff;
    border: 2px solid #fde047;
    border-radius: var(--radius-md);
    padding: .9rem 1.4rem;
    min-width: 80px;
    box-shadow: 0 4px 16px rgba(250,204,21,.2);
  }

  .spring__unit-val {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 700;
    color: #c48f00;
    line-height: 1;
    min-width: 2ch;
    text-align: center;
  }

  .spring__unit-label {
    font-size: .7rem;
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: #a07200;
    margin-top: .3rem;
  }

  .spring__unit-sep {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    color: #fbbf24;
    align-self: flex-start;
    margin-top: .5rem;
  }

  /* ── Meanings ── */
  .spring__meanings {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    list-style: none;
    margin-bottom: 3rem;
  }

  .spring__meaning {
    background: #fff;
    border: 1.5px solid #fde047;
    border-radius: var(--radius-md);
    padding: 1.5rem 1.25rem;
    text-align: center;
    transition: transform var(--transition), box-shadow var(--transition);
  }

  .spring__meaning:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(250,204,21,.28);
  }

  .spring__meaning-icon {
    display: block;
    font-size: 2.25rem;
    margin-bottom: .65rem;
    line-height: 1;
  }

  .spring__meaning-label {
    display: block;
    font-size: .9375rem;
    font-weight: 700;
    color: #7c5800;
    margin-bottom: .4rem;
  }

  .spring__meaning-desc {
    font-size: .8125rem;
    color: #9a7200;
    line-height: 1.55;
  }

  /* ── Mosaic ── */
  .spring__mosaic {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    grid-template-rows: auto auto;
    gap: .875rem;
    margin-bottom: 3rem;
  }

  .spring__photo {
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid #fde047;
    box-shadow: 0 10px 30px rgba(250, 204, 21, 0.08);
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
  }

  .spring__photo-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(120,85,0,.75) 0%, rgba(120,85,0,.1) 60%, transparent 100%);
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: .75rem;
    opacity: 0;
    transition: opacity .25s ease;
  }

  .spring__photo:hover .spring__photo-overlay { opacity: 1; }

  .spring__photo-cta {
    display: inline-flex;
    align-items: center;
    gap: .35rem;
    background: #25d366;
    color: #fff;
    border: none;
    border-radius: var(--radius-lg);
    padding: .42rem 1rem;
    font-size: .78rem;
    font-weight: 700;
    font-family: var(--font-body);
    cursor: pointer;
    transition: background .15s, transform .15s;
    box-shadow: 0 3px 10px rgba(0,0,0,.25);
    white-space: nowrap;
  }

  .spring__photo-cta:hover { background: #1ebe5c; transform: translateY(-1px); }

  .spring__photo:hover {
    transform: translateY(-8px) scale(1.02);
    box-shadow: 0 20px 40px rgba(250, 204, 21, 0.25);
    z-index: 1;
    position: relative;
  }

  /* Featured items */
  .spring__photo--0 { grid-column: span 2; grid-row: span 2; }
  .spring__photo--5 { grid-column: span 2; }

  .spring__photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform .5s ease;
  }

  .spring__photo:hover .spring__photo-img { transform: scale(1.06); }

  /* ── CTA ── */
  .spring__cta {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .spring__cta-text {
    font-size: 1.0625rem;
    color: #6b5200;
    max-width: 52ch;
  }

  .spring__btn {
    background: linear-gradient(135deg, #f59e0b 0%, #fbbf24 100%);
    color: #fff;
    border: none;
    font-size: 1rem;
    padding: 1rem 2.25rem;
    box-shadow: 0 6px 20px rgba(245,158,11,.45);
    transition: transform var(--transition), box-shadow var(--transition);
  }

  .spring__btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 30px rgba(245,158,11,.55);
    background: linear-gradient(135deg, #d97706 0%, #f59e0b 100%);
  }

  .spring__urgency {
    font-size: .875rem;
    font-weight: 600;
    color: #b45309;
    min-height: 1.4rem;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .spring__meanings { grid-template-columns: repeat(2, 1fr); }
    .spring__mosaic   { grid-template-columns: repeat(3, 1fr); }
    .spring__photo--0 { grid-column: span 1; grid-row: span 1; }
    .spring__photo--5 { grid-column: span 1; }
  }

  @media (max-width: 600px) {
    .spring__meanings { grid-template-columns: 1fr 1fr; }
    .spring__mosaic   { grid-template-columns: repeat(2, 1fr); }
    .spring__unit     { min-width: 64px; padding: .7rem 1rem; }
  }

  @media (max-width: 400px) {
    .spring__mosaic { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<script>
  // ── Countdown to March 21 ──
  function getTarget(): Date {
    const now = new Date();
    let year  = now.getFullYear();
    const target = new Date(year, 2, 21, 0, 0, 0); // March = 2 (0-indexed)
    if (now >= target) target.setFullYear(year + 1);
    return target;
  }

  function pad(n: number): string {
    return String(n).padStart(2, '0');
  }

  const daysEl  = document.getElementById('cdDays')!;
  const hoursEl = document.getElementById('cdHours')!;
  const minsEl  = document.getElementById('cdMins')!;
  const secsEl  = document.getElementById('cdSecs')!;
  const urgency = document.getElementById('springUrgency')!;

  function tick() {
    const diff = getTarget().getTime() - Date.now();
    if (diff <= 0) {
      daysEl.textContent  = '00';
      hoursEl.textContent = '00';
      minsEl.textContent  = '00';
      secsEl.textContent  = '00';
      urgency.textContent = '🌼 ¡Hoy es el Día de las Flores Amarillas!';
      return;
    }

    const days  = Math.floor(diff / 86_400_000);
    const hours = Math.floor((diff % 86_400_000) / 3_600_000);
    const mins  = Math.floor((diff % 3_600_000)  / 60_000);
    const secs  = Math.floor((diff % 60_000)      / 1_000);

    daysEl.textContent  = pad(days);
    hoursEl.textContent = pad(hours);
    minsEl.textContent  = pad(mins);
    secsEl.textContent  = pad(secs);

    if (days <= 7) {
      urgency.textContent = `⚡ ¡Solo quedan ${days} día${days !== 1 ? 's' : ''}! Reserva antes de que se agoten los arreglos.`;
    } else if (days <= 21) {
      urgency.textContent = `🌼 Faltan ${days} días — junta tus pedidos con tiempo.`;
    }
  }

  tick();
  setInterval(tick, 1000);

  // ── Cotizar buttons ──
  document.querySelectorAll<HTMLButtonElement>('.spring__photo-cta').forEach(btn => {
    btn.addEventListener('click', e => {
      e.stopPropagation();
      const src = btn.dataset.src!;
      const alt = btn.dataset.alt!;
      const imgUrl = window.location.origin + (src.startsWith('/') ? src : '/' + src);
      const msg = `Hola! Me interesa cotizar este arreglo de flores amarillas 🌼\n\nArreglo: *${alt}*\nImagen: ${imgUrl}`;
      window.open(`https://wa.me/5212371113802?text=${encodeURIComponent(msg)}`, '_blank', 'noopener,noreferrer');
    });
  });
</script>
