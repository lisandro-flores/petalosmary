---
const steps = [
  {
    num: '01',
    title: 'Escríbenos',
    desc: 'Cuéntanos tu idea, la ocasión y tu presupuesto por WhatsApp. Te atendemos pronto.',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>`,
  },
  {
    num: '02',
    title: 'Diseñamos juntas',
    desc: 'Te enviamos opciones de flores, colores y presentación. Ajustamos hasta que sea exactamente lo que imaginas.',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 22C6.477 22 2 17.523 2 12S6.477 2 12 2s10 4.477 10 10-4.477 10-10 10zm-1-11v6h2v-6h-2zm0-4v2h2V7h-2z"/></svg>`,
  },
  {
    num: '03',
    title: 'Entregamos con amor',
    desc: 'Tu arreglo llega fresco y con una presentación cuidada, listo para sorprender en la fecha especial.',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>`,
  },
];
---

<section class="process" id="proceso" aria-labelledby="process-title">
  <div class="container">
    <div class="process__header reveal">
      <span class="section-label">Proceso</span>
      <h2 class="section-title" id="process-title">Pedir es <em>muy sencillo</em></h2>
      <p class="section-body process__intro">
        Te acompañamos desde la idea hasta la entrega. Sin formularios complicados.
      </p>
    </div>

    <div class="process__steps">
      {steps.map((step, idx) => (
        <div class="process__step reveal" style={`transition-delay: ${idx * 120}ms;`}>
          <div class="process__connector" aria-hidden="true"></div>
          <div class="process__icon-wrap">
            <span class="process__icon" set:html={step.icon} />
          </div>
          <span class="process__num">{step.num}</span>
          <h3 class="process__name">{step.title}</h3>
          <p class="process__desc">{step.desc}</p>
        </div>
      ))}
    </div>

    <div class="process__cta reveal">
      <a
        href="https://wa.me/5212371113802?text=Hola%2C%20quiero%20cotizar%20un%20arreglo%20floral"
        class="btn btn-primary"
        target="_blank"
        rel="noreferrer"
      >
        Empezar ahora
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .process {
    padding: 6rem 0 7rem;
    background: linear-gradient(180deg, var(--color-bg) 0%, #fff8fb 100%);
    position: relative;
  }

  .process__header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .process__intro {
    margin-inline: auto;
    margin-top: 1rem;
    text-align: center;
  }

  .process__steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    max-width: 900px;
    margin: 0 auto;
    position: relative;
  }

  /* Linea horizontal conectora (desktop) */
  .process__steps::before {
    content: '';
    position: absolute;
    top: 3.25rem;
    left: calc(16.67% + 1.5rem);
    right: calc(16.67% + 1.5rem);
    height: 1px;
    background: linear-gradient(90deg, var(--color-border) 0%, var(--color-primary) 50%, var(--color-border) 100%);
    z-index: 0;
  }

  .process__step {
    text-align: center;
    position: relative;
    z-index: 1;
  }

  /* Linea a la derecha (no mostrar en el último) */
  .process__connector {
    display: none;
  }

  .process__icon-wrap {
    width: 6rem;
    height: 6rem;
    border-radius: 50%;
    background: #fff;
    border: 2px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.25rem;
    box-shadow: 0 8px 24px rgba(172, 28, 84, 0.1);
    transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition), background var(--transition);
    color: var(--color-primary);
    position: relative;
    z-index: 2;
    background: linear-gradient(135deg, #fff 0%, #fff0f3 100%);
  }

  .process__step:hover .process__icon-wrap {
    transform: translateY(-4px) scale(1.05);
    box-shadow: 0 16px 40px rgba(172, 28, 84, 0.18);
    border-color: var(--color-primary);
    background: linear-gradient(135deg, #fff 0%, #fce4ec 100%);
  }

  .process__num {
    display: block;
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
    opacity: 0.8;
  }

  .process__name {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 0.65rem;
    letter-spacing: -0.01em;
  }

  .process__desc {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.7;
    max-width: 22ch;
    margin-inline: auto;
  }

  .process__cta {
    text-align: center;
    margin-top: 4rem;
  }

  @media (max-width: 700px) {
    .process__steps {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      max-width: 400px;
    }

    .process__steps::before {
      display: none;
    }

    .process__desc {
      max-width: 100%;
    }
  }
</style>
