---
const steps = [
  { num: '01', title: 'Escríbenos', desc: 'Cuéntanos tu idea por WhatsApp' },
  { num: '02', title: 'Cotizamos', desc: 'Te enviamos opciones y precios' },
  { num: '03', title: 'Entregamos', desc: 'Recibe tu arreglo a domicilio' },
];
---

<section class="process" aria-labelledby="process-title">
  <div class="container">
    <h2 class="process__title" id="process-title">¿Cómo funciona?</h2>
    
    <div class="process__steps">
      {steps.map((step, idx) => (
        <div class="process__step">
          <span class="process__num">{step.num}</span>
          <h3 class="process__name">{step.title}</h3>
          <p class="process__desc">{step.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .process {
    padding: 4rem 0;
    background: #fafafa;
  }

  .process__title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    text-align: center;
    color: var(--color-text);
    margin: 0 0 3rem;
  }

  .process__steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .process__step {
    text-align: center;
  }

  .process__num {
    display: block;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .process__name {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 0.5rem;
  }

  .process__desc {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.6;
  }

  @media (max-width: 640px) {
    .process__steps {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
