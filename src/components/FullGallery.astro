---
import { FALLBACK_GALLERY, FALLBACK_SPRING } from '../lib/fallback';

// Combinar todas las imágenes
const allImages = [
  ...FALLBACK_SPRING.map(img => ({ ...img, type: 'amarillas' })),
  ...FALLBACK_GALLERY.map(img => ({ ...img, type: img.category })),
];
---

<div class="gallery-modal" id="galleryModal" hidden>
  <div class="gallery-modal__backdrop" id="closeGallery"></div>
  
  <div class="gallery-modal__content">
    <header class="gallery-modal__header">
      <h2 class="gallery-modal__title">Todos nuestros trabajos</h2>
      <button type="button" class="gallery-modal__close" id="closeGalleryBtn" aria-label="Cerrar galería">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>
    </header>

    <div class="gallery-modal__grid">
      {allImages.map((img, idx) => (
        <a
          href={`https://wa.me/5212371113802?text=Hola%2C%20me%20interesa%20este%20arreglo:%20${encodeURIComponent(img.alt)}`}
          class="gallery-modal__item"
          target="_blank"
          rel="noreferrer"
        >
          <img
            src={img.src}
            alt={img.alt}
            loading="lazy"
            decoding="async"
          />
          <span class="gallery-modal__overlay"></span>
        </a>
      ))}
    </div>
  </div>
</div>

<style>
  .gallery-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 2.5rem;
    overflow-y: auto;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--transition);
  }

  .gallery-modal:not([hidden]) {
    display: flex;
    opacity: 1;
    pointer-events: auto;
  }

  .gallery-modal[hidden] {
    display: none;
  }

  .gallery-modal__backdrop {
    position: fixed;
    inset: 0;
    background: rgba(28, 25, 26, 0.4);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
  }

  .gallery-modal__content {
    position: relative;
    background: var(--color-bg);
    border-radius: 2rem;
    width: 100%;
    max-width: 1200px;
    padding: 3.5rem;
    margin: 2rem 0;
    box-shadow: 0 32px 80px rgba(28, 25, 26, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.5);
    transform: translateY(20px) scale(0.98);
    transition: transform var(--transition);
  }

  .gallery-modal:not([hidden]) .gallery-modal__content {
    transform: translateY(0) scale(1);
  }

  .gallery-modal__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 3.5rem;
  }

  .gallery-modal__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 500;
    color: var(--color-text);
    margin: 0;
    letter-spacing: -0.02em;
  }

  .gallery-modal__close {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    border-radius: 50%;
    width: 54px;
    height: 54px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition), background var(--transition), color var(--transition);
  }

  .gallery-modal__close:hover {
    background: var(--color-primary);
    color: #fff;
    border-color: var(--color-primary);
    transform: rotate(90deg) scale(1.05);
  }

  .gallery-modal__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .gallery-modal__item {
    position: relative;
    aspect-ratio: 4/5;
    overflow: hidden;
    border-radius: 1.25rem;
    background: var(--color-surface);
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition), box-shadow var(--transition);
  }

  .gallery-modal__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .gallery-modal__item:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
  }

  .gallery-modal__item:hover img {
    transform: scale(1.08);
  }

  .gallery-modal__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(28,25,26,0.5) 0%, rgba(28,25,26,0) 50%);
    color: #fff;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-bottom: 2rem;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    opacity: 0;
    transition: opacity var(--transition);
  }

  .gallery-modal__overlay::after {
    content: 'Solicitar';
    padding: 0.6rem 1.5rem;
    background: rgba(255,255,255,0.2);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.4);
    border-radius: 999px;
    transform: translateY(15px);
    transition: transform var(--transition);
  }

  .gallery-modal__item:hover .gallery-modal__overlay {
    opacity: 1;
  }
  
  .gallery-modal__item:hover .gallery-modal__overlay::after {
    transform: translateY(0);
  }

  @media (max-width: 640px) {
    .gallery-modal {
      padding: 1rem;
    }

    .gallery-modal__content {
      padding: 2rem 1.5rem;
      border-radius: 1.5rem;
    }

    .gallery-modal__header {
      margin-bottom: 2.5rem;
    }

    .gallery-modal__grid {
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
      gap: 1rem;
    }
    
    .gallery-modal__item {
      aspect-ratio: 1;
    }
  }
</style>

<script>
  const modal = document.getElementById('galleryModal');
  const openBtns = document.querySelectorAll('.open-gallery-btn');
  const closeBtn = document.getElementById('closeGalleryBtn');
  const backdrop = document.getElementById('closeGallery');

  function openModal() {
    modal?.removeAttribute('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal?.setAttribute('hidden', '');
    document.body.style.overflow = '';
  }

  openBtns.forEach(btn => btn.addEventListener('click', openModal));
  closeBtn?.addEventListener('click', closeModal);
  backdrop?.addEventListener('click', closeModal);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal?.hasAttribute('hidden')) {
      closeModal();
    }
  });
</script>
