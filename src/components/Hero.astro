---
---

<section class="hero" id="inicio" aria-label="Bienvenida">
  <!-- Decorative blobs -->
  <div class="hero__blob hero__blob--1" aria-hidden="true"></div>
  <div class="hero__blob hero__blob--2" aria-hidden="true"></div>

  <div class="container hero__inner">
    <!-- Text -->
    <div class="hero__text reveal">

      <h1 class="hero__title">
        Flores que <em>hablan</em><br>por ti
      </h1>
      <p class="hero__subtitle">
        Creamos arreglos florales únicos para cada momento especial.
        Bodas, cumpleaños, eventos corporativos y mucho más.
      </p>
      <div class="hero__actions">
        <a href="#galeria" class="btn btn-primary">
          Ver arreglos
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="#contacto" class="btn btn-outline">Hacer un pedido</a>
      </div>
    </div>

    <!-- Visual card -->
    <div class="hero__visual reveal" style="transition-delay: 200ms;">
      <div class="hero__card">
        <img
          src="/images/IMG-20241122-WA0002.jpg"
          alt="Arreglo floral artesanal Pétalos Mary"
          class="hero__photo"
          width="540"
          height="540"
          loading="eager"
          decoding="async"
        />
        <div class="hero__card-badge">
          <span class="hero__badge-icon" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l2.9 6.1L21 9.3l-4.5 3.4L17 21l-5-2.6L7 21l.5-8.3L3 9.3l6.1-1.2L12 2z"/></svg>
          </span>
          <span>Entrega a domicilio</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll cue -->
  <a href="#galeria" class="hero__scroll" aria-label="Desplazarse hacia abajo">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    padding-block: 5.5rem 4rem;
  }

  /* Blobs */
  .hero__blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
    z-index: 0;
  }

  .hero__blob--1 {
    width: clamp(400px, 60vw, 800px);
    height: clamp(400px, 60vw, 800px);
    background: radial-gradient(circle, rgba(214,51,132,0.25) 0%, transparent 70%);
    top: -15%;
    right: -10%;
  }

  .hero__blob--2 {
    width: clamp(300px, 40vw, 600px);
    height: clamp(300px, 40vw, 600px);
    background: radial-gradient(circle, rgba(255,193,7,0.15) 0%, transparent 70%);
    bottom: -5%;
    left: -10%;
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: clamp(2rem, 5vw, 5rem);
    min-height: calc(100svh - 68px);
    padding-block: 4rem 2rem;
  }

  /* Text */
  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5.5vw, 4.25rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -.01em;
    margin-block: .75rem 1.25rem;
    color: var(--color-text);
  }

  .hero__title em {
    font-style: italic;
    color: var(--color-primary);
  }

  .hero__subtitle {
    font-size: clamp(.95rem, 1.5vw, 1.125rem);
    color: var(--color-text-muted);
    max-width: 48ch;
    line-height: 1.75;
    margin-bottom: 2rem;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: .875rem;
    align-items: center;
    margin-bottom: 2.5rem;
  }

  /* Stats */
  .hero__stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .hero__stat { text-align: left; }

  .hero__stat-value {
    display: block;
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1;
    margin-bottom: .2rem;
  }

  .hero__stat-label {
    font-size: .8125rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .hero__stat-sep {
    width: 1px;
    height: 2.5rem;
    background: var(--color-border);
    flex-shrink: 0;
  }

  /* Visual */
  .hero__visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero__card {
    position: relative;
    width: clamp(280px, 40vw, 500px);
    aspect-ratio: 1;
    border-radius: 40% 60% 55% 45% / 45% 50% 50% 55%;
    box-shadow: var(--shadow-lg);
    overflow: hidden;
    animation: morphBlob 8s ease-in-out infinite;
  }

  @keyframes morphBlob {
    0%, 100% { border-radius: 40% 60% 55% 45% / 45% 50% 50% 55%; }
    33%       { border-radius: 55% 45% 40% 60% / 55% 40% 60% 45%; }
    66%       { border-radius: 45% 55% 60% 40% / 40% 60% 45% 55%; }
  }

  .hero__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .6s ease;
  }

  .hero__card:hover .hero__photo { transform: scale(1.05); }

  /* Badges */
  .hero__card-badge,
  .hero__card-badge2 {
    position: absolute;
    display: flex;
    align-items: center;
    gap: .45rem;
    background: #fff;
    color: var(--color-text);
    font-size: .8125rem;
    font-weight: 600;
    padding: .55rem 1rem;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }

  .hero__card-badge {
    bottom: 14%;
    right: -8%;
    animation: floatBadge 3s ease-in-out infinite;
  }

  .hero__card-badge2 {
    top: 10%;
    left: -8%;
    animation: floatBadge 3s ease-in-out infinite;
    animation-delay: 1.5s;
  }

  .hero__badge-icon { color: var(--color-primary); }

  @keyframes floatBadge {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-6px); }
  }

  /* Scroll cue */
  .hero__scroll {
    position: absolute;
    bottom: 1.75rem;
    left: 50%;
    transform: translateX(-50%);
    color: var(--color-text-muted);
    opacity: .5;
    transition: opacity var(--transition);
    animation: bounceDown 2s ease-in-out infinite;
  }

  .hero__scroll:hover { opacity: 1; }

  @keyframes bounceDown {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50%       { transform: translateX(-50%) translateY(6px); }
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero__inner {
      grid-template-columns: 1fr;
      text-align: center;
      padding-block: 6rem 3rem;
      gap: 2.5rem;
      min-height: unset;
    }

    .hero__actions   { justify-content: center; }
    .hero__stats     { justify-content: center; }
    .hero__subtitle  { margin-inline: auto; }
    .hero__visual    { order: -1; }

    .hero__card {
      width: clamp(220px, 72vw, 360px);
    }

    .hero__card-badge  { right: 0; bottom: 8%; font-size: .75rem; padding: .4rem .8rem; }
    .hero__card-badge2 { left: 0; top: 6%; font-size: .75rem; padding: .4rem .8rem; }
  }
</style>
