---
import { Image } from 'astro:assets';
import heroImg from '../assets/images/padre.jpeg';
---

<section class="hero" id="inicio" aria-label="Bienvenida — Pétalos Mary">
  <!-- Subtle editorial lighting instead of heavy pink blobs -->
  <div class="hero__bg-decor hero__bg-decor--elegant"></div>

  <div class="container hero__inner">
    <div class="hero__content">
      <div class="hero__badge-wrapper">
        <span class="hero__badge">
          <span class="hero__badge-dot"></span>
          Especial Día del Padre
        </span>
      </div>
      
      <h1 class="hero__title">
        Detalles que celebran<br>
        <em>a papá en su día</em>
      </h1>
      
      <p class="hero__subtitle">
        Arreglos florales únicos y elegantes, pensados para sorprender a papá. Entrega local en San José Buenavista y zonas cercanas de San Marcos Tlacoyalco.
      </p>

      <div class="hero__actions">
        <a href="https://wa.me/5212371113802?text=Hola%2C%20quiero%20cotizar%20un%20arreglo%20floral" class="hero__cta" target="_blank" rel="noreferrer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Cotizar arreglo
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="#galeria" class="hero__secondary">
          Ver galería
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
        </a>
      </div>

      <div class="hero__trust">
        <div class="hero__trust-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
          Hecho a mano
        </div>
        <div class="hero__trust-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          Entrega en San José Buenavista y zonas cercanas de San Marcos Tlacoyalco
        </div>
        <div class="hero__trust-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          Atención personalizada
        </div>
      </div>
    </div>

    <div class="hero__image">
      <div class="hero__image-frame">
        <Image
          src={heroImg}
          alt="Arreglo floral elegante del Día del Padre por Pétalos Mary"
          width="600"
          height="750"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
        <div class="hero__image-glow"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding: 6rem 0 5rem;
    background: linear-gradient(160deg, #ffffff 0%, #faf9f8 50%, #f3efec 100%);
    position: relative;
    overflow: hidden;
  }

  /* Subtle, elegant light flare */
  .hero__bg-decor--elegant {
    position: absolute;
    top: -10%;
    right: 5%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(254, 205, 211, 0.15) 0%, transparent 70%);
    z-index: 0;
    pointer-events: none;
    border-radius: 50%;
    filter: blur(40px);
    animation: gentleBreathe 8s ease-in-out infinite alternate;
  }

  @keyframes gentleBreathe {
    0% { transform: scale(1); opacity: 0.8; }
    100% { transform: scale(1.05); opacity: 1; }
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(3rem, 6vw, 6rem);
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .hero__content {
    max-width: 620px;
    position: relative;
  }

  .hero__badge-wrapper {
    margin-bottom: 2rem;
    animation: fadeDown 0.8s ease-out;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: #1e3a8a;
    font-size: 0.825rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.55rem 1.2rem;
    border-radius: 999px;
    border: 1px solid rgba(254, 205, 211, 0.6);
    box-shadow: 0 4px 16px rgba(159, 18, 57, 0.08);
  }

  .hero__badge-dot {
    width: 8px;
    height: 8px;
    background: #10b981;
    border-radius: 50%;
    display: inline-block;
    animation: pulse 2s ease-in-out infinite;
    box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4);
  }

  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4); }
    50%      { box-shadow: 0 0 0 6px rgba(16, 185, 129, 0); }
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 5.5vw, 4.8rem);
    font-weight: 600;
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: #2d1f24;
    margin: 0 0 1.5rem;
    animation: fadeUp 0.8s ease-out 0.15s both;
  }

  .hero__title em {
    font-style: italic;
    color: #1e3a8a;
    font-weight: 500;
    position: relative;
    display: inline-block;
  }
  
  .hero__title em::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: -2px;
    right: -2px;
    height: 14px;
    background: linear-gradient(90deg, rgba(253, 164, 175, 0.3), rgba(254, 205, 211, 0.4));
    z-index: -1;
    border-radius: 4px;
    transform: skewX(-3deg);
  }

  .hero__subtitle {
    font-family: var(--font-body);
    font-size: clamp(1.05rem, 1.4vw, 1.2rem);
    color: #6b4755;
    font-weight: 400;
    line-height: 1.8;
    margin: 0 0 2.25rem;
    max-width: 480px;
    animation: fadeUp 0.8s ease-out 0.3s both;
  }

  .hero__actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    animation: fadeUp 0.8s ease-out 0.45s both;
  }

  .hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: linear-gradient(135deg, #1e3a8a 0%, #172554 100%);
    color: #fff;
    padding: 1rem 2rem;
    border-radius: 999px;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    text-decoration: none;
    transition: transform var(--transition), box-shadow var(--transition), background var(--transition);
    box-shadow: 0 8px 28px rgba(30, 58, 138, 0.3);
    position: relative;
    overflow: hidden;
  }

  .hero__cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.15) 0%, transparent 50%);
    border-radius: inherit;
  }

  .hero__cta:hover {
    transform: translateY(-3px) scale(1.02);
    box-shadow: 0 14px 36px rgba(30, 58, 138, 0.4);
  }

  .hero__cta:focus-visible {
    outline: 2px solid #2563eb;
    outline-offset: 4px;
  }

  .hero__secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #6b4755;
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: none;
    transition: color var(--transition), transform var(--transition);
    padding: 0.5rem 0;
    border-bottom: 1.5px solid rgba(30, 58, 138, 0.2);
  }

  .hero__secondary:hover {
    color: #1e3a8a;
    transform: translateY(-1px);
    border-bottom-color: #1e3a8a;
  }

  .hero__secondary svg {
    animation: bounceDown 2s ease-in-out infinite;
  }

  @keyframes bounceDown {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(3px); }
  }

  /* Trust badges strip */
  .hero__trust {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(30, 58, 138, 0.08);
    animation: fadeUp 0.8s ease-out 0.6s both;
  }

  .hero__trust-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: #7c5264;
  }

  .hero__trust-item svg {
    color: #1e3a8a;
    flex-shrink: 0;
  }

  /* Hero image composition */
  .hero__image {
    position: relative;
    animation: fadeIn 1.2s ease-out 0.3s both;
  }

  .hero__image-frame {
    position: relative;
    border-radius: 2rem;
    overflow: hidden;
    background: #fff;
    box-shadow: 0 24px 48px rgba(30, 58, 138, 0.1), 0 8px 16px rgba(0,0,0,0.04);
  }

  .hero__image-glow {
    position: absolute;
    inset: -20%;
    background: radial-gradient(circle at 50% 80%, rgba(253, 164, 175, 0.3) 0%, transparent 60%);
    pointer-events: none;
    z-index: 1;
  }

  .hero__image img {
    width: 100%;
    max-width: 520px;
    aspect-ratio: 4/5;
    object-fit: cover;
    display: block;
    transition: transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .hero__image-frame:hover img {
    transform: scale(1.04);
  }

  /* Floating info cards */
  .hero__image-card {
    position: absolute;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.6);
    border-radius: 1rem;
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
    font-size: 0.8rem;
    font-weight: 600;
    color: #2d1f24;
    line-height: 1.3;
    z-index: 2;
  }

  .hero__image-card small {
    font-weight: 400;
    color: #7c5264;
    font-size: 0.72rem;
  }

  .hero__card-emoji {
    font-size: 1.5rem;
  }

  .hero__image-card--top {
    top: 8%;
    right: -1rem;
    animation: floatCard 5s ease-in-out infinite;
  }

  .hero__image-card--bottom {
    bottom: 12%;
    left: -1.5rem;
    animation: floatCard 5s ease-in-out infinite 1.5s;
  }

  @keyframes floatCard {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-8px); }
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeDown {
    from { opacity: 0; transform: translateY(-15px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: scale(0.96); }
    to { opacity: 1; transform: scale(1); }
  }

  @media (max-width: 900px) {
    .hero {
      padding: 7rem 0 4rem;
      min-height: auto;
    }

    .hero__inner {
      grid-template-columns: 1fr;
      gap: 3rem;
      text-align: center;
    }

    .hero__content {
      max-width: 100%;
      order: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .hero__subtitle {
      margin-inline: auto;
    }

    .hero__actions {
      justify-content: center;
    }

    .hero__trust {
      justify-content: center;
    }

    .hero__image {
      order: 2;
      display: flex;
      justify-content: center;
      margin: 0 auto;
      max-width: 380px;
    }

    .hero__image-card--top {
      right: -0.5rem;
      top: 5%;
    }

    .hero__image-card--bottom {
      left: -0.5rem;
      bottom: 8%;
    }
  }

  @media (max-width: 480px) {
    .hero__trust {
      gap: 1rem;
    }
    
    .hero__image-card {
      font-size: 0.72rem;
      padding: 0.6rem 0.8rem;
    }

    .hero__card-emoji {
      font-size: 1.2rem;
    }
  }
</style>
