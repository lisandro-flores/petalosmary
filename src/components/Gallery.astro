---
import { FALLBACK_GALLERY } from '../lib/fallback';
import type { GalleryItem } from '../lib/fallback';

interface Props { items?: GalleryItem[]; }
const { items = FALLBACK_GALLERY } = Astro.props;
---

<section class="gallery section" id="galeria" aria-labelledby="gallery-title">
  <div class="container">
    <div class="gallery__header reveal">
      <span class="section-label">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l2.9 6.1L21 9.3l-4.5 3.4L17 21l-5-2.6L7 21l.5-8.3L3 9.3l6.1-1.2L12 2z"/></svg>
        Nuestro trabajo
      </span>
      <h2 class="section-title" id="gallery-title">Cada flor, una <em>historia</em></h2>
      <p class="section-body gallery__subtitle">
        Explora nuestra colección. Haz clic en cualquier imagen para verla y cotizar.
      </p>
    </div>

    <!-- pagination added below -->

    <div class="gallery__mosaic" id="galleryGrid">
      {items.map((item, idx) => (
        <div
          class={`gallery__tile${idx === 0 ? ' gallery__tile--featured' : ''}`}
          data-category={item.category}
          data-src={item.src}
          data-alt={item.alt}
          data-index={idx}
          role="button"
          tabindex="0"
          aria-label={`Ver: ${item.alt}`}
        >
          <img
            src={item.src}
            alt={item.alt}
            loading={idx < 8 ? 'eager' : 'lazy'}
            decoding="async"
            class="gallery__tile-img"
          />
          <div class="gallery__tile-overlay">
            <p class="gallery__tile-name">{item.alt}</p>
            <button
              class="gallery__tile-cta"
              type="button"
              data-src={item.src}
              data-alt={item.alt}
              aria-label={`Cotizar ${item.alt}`}
            >
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg>
              Cotizar
            </button>
          </div>
        </div>
      ))}
    </div>
    <div class="gallery__pagination" id="galleryPagination" aria-label="Paginación de galería">
      <button class="gallery__page-btn" id="pagePrev" disabled>Anterior</button>
      <div id="pageNumbers" class="gallery__page-numbers"></div>
      <button class="gallery__page-btn" id="pageNext" disabled>Siguiente</button>
    </div>
  </div>
</section>

<div class="lb" id="lightbox" role="dialog" aria-modal="true" aria-label="Vista de imagen" hidden>
  <button class="lb__close" id="lbClose" aria-label="Cerrar">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
  </button>
  <button class="lb__nav lb__nav--prev" id="lbPrev" aria-label="Anterior">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
  </button>
  <div class="lb__body">
    <div class="lb__img-wrap">
      <img src="" alt="" id="lbImg" class="lb__img" />
    </div>
    <div class="lb__info">
      <p class="lb__caption" id="lbCaption"></p>
      <span class="lb__counter" id="lbCounter" aria-live="polite"></span>
      <button class="lb__cotizar" id="lbCotizar" type="button">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg>
        Cotizar este arreglo por WhatsApp
      </button>
    </div>
  </div>
  <button class="lb__nav lb__nav--next" id="lbNext" aria-label="Siguiente">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
  </button>
</div>

<style>
  .gallery__header { text-align: center; margin-bottom: 2.5rem; }
  .gallery__subtitle { margin-inline: auto; margin-top: .875rem; }

  /* pagination controls */
  .gallery__pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }

  .gallery__page-btn,
  .gallery__page-num {
    background: #fff;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: .5rem .9rem;
    font-size: .875rem;
    font-weight: 600;
    font-family: var(--font-body);
    cursor: pointer;
    transition: background var(--transition), border-color var(--transition), color var(--transition);
  }

  .gallery__page-btn:disabled { opacity: .5; cursor: default; }

  .gallery__page-num.is-active {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: #fff;
  }

  .gallery__page-numbers {
    display: flex;
    gap: .6rem;
  }

  .gallery__page-num {
    min-width: 2ch;
    text-align: center;
    transition: background var(--transition), color var(--transition);
  }

  .gallery__page-num:hover:not(.is-active) {
    background: var(--color-accent);
    color: var(--color-primary);
  }


  /* ── Mosaic (same style as SpringYellow) ── */
  .gallery__mosaic {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    grid-auto-rows: 220px;
    gap: .875rem;
  }

  .gallery__tile--featured { grid-column: span 2; grid-row: span 2; }

  .gallery__tile {
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--color-border);
    box-shadow: 0 10px 30px rgba(214, 51, 132, 0.05);
    position: relative;
    cursor: pointer;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .gallery__tile:hover {
    transform: translateY(-8px) scale(1.02);
    box-shadow: 0 20px 40px rgba(214, 51, 132, 0.15);
    border-color: var(--color-primary);
    z-index: 2;
  }

  .gallery__tile.is-hidden { display: none; }
  .gallery__tile:focus-visible { outline: 3px solid var(--color-primary); outline-offset: 2px; }

  .gallery__tile-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform .5s ease;
  }

  .gallery__tile:hover .gallery__tile-img { transform: scale(1.07); }

  .gallery__tile-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(100,30,55,.82) 0%, rgba(100,30,55,.15) 60%, transparent 100%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: center;
    padding: .875rem .75rem;
    opacity: 0;
    transition: opacity .25s ease;
    gap: .55rem;
  }

  .gallery__tile:hover .gallery__tile-overlay { opacity: 1; }

  .gallery__tile-name {
    color: #fff;
    font-size: .8rem;
    font-weight: 600;
    text-align: center;
    line-height: 1.3;
    text-shadow: 0 1px 4px rgba(0,0,0,.5);
  }

  .gallery__tile-cta {
    display: inline-flex;
    align-items: center;
    gap: .35rem;
    background: #25d366;
    color: #fff;
    border: none;
    border-radius: var(--radius-lg);
    padding: .42rem 1rem;
    font-size: .78rem;
    font-weight: 700;
    font-family: var(--font-body);
    cursor: pointer;
    transition: background .15s, transform .15s;
    box-shadow: 0 3px 10px rgba(0,0,0,.25);
    white-space: nowrap;
  }

  .gallery__tile-cta:hover { background: #1ebe5c; transform: translateY(-1px); }

  /* ── Lightbox ── */
  .lb {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(10,4,6,.93);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    animation: lbIn .2s ease;
  }

  .lb[hidden] { display: none; }
  @keyframes lbIn { from { opacity: 0; } to { opacity: 1; } }

  .lb__body {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    max-width: min(88vw, 860px);
    max-height: 90svh;
  }

  .lb__img-wrap { display: flex; align-items: center; justify-content: center; flex: 1; min-height: 0; }

  .lb__img {
    max-width: 100%;
    max-height: 68svh;
    object-fit: contain;
    border-radius: var(--radius-md);
    box-shadow: 0 24px 80px rgba(0,0,0,.6);
    border: 3px solid rgba(255,255,255,.12);
    animation: lbImgIn .2s ease;
  }

  @keyframes lbImgIn { from { opacity:0; transform:scale(.95); } to { opacity:1; transform:scale(1); } }

  .lb__info {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    justify-content: center;
    background: rgba(255,255,255,.07);
    border: 1px solid rgba(255,255,255,.12);
    border-radius: var(--radius-md);
    padding: .875rem 1.5rem;
    width: 100%;
    max-width: 600px;
  }

  .lb__caption { color: rgba(255,255,255,.85); font-size: .9375rem; font-weight: 500; font-family: var(--font-display); font-style: italic; flex: 1; text-align: center; }
  .lb__counter { color: rgba(255,255,255,.45); font-size: .78rem; font-weight: 600; letter-spacing: .06em; white-space: nowrap; }

  .lb__cotizar {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    background: #25d366;
    color: #fff;
    border: none;
    border-radius: var(--radius-lg);
    padding: .65rem 1.5rem;
    font-size: .9375rem;
    font-weight: 700;
    font-family: var(--font-body);
    cursor: pointer;
    transition: background .15s, transform .15s;
    box-shadow: 0 4px 16px rgba(0,0,0,.3);
    white-space: nowrap;
  }

  .lb__cotizar:hover { background: #1ebe5c; transform: translateY(-2px); }

  .lb__close {
    position: absolute;
    top: 1.25rem; right: 1.25rem;
    background: rgba(255,255,255,.12);
    border: none; color: #fff;
    width: 44px; height: 44px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    transition: background var(--transition), transform var(--transition);
    z-index: 2;
  }

  .lb__close:hover { background: rgba(255,255,255,.25); transform: rotate(90deg); }

  .lb__nav {
    position: absolute;
    top: 50%; transform: translateY(-50%);
    background: rgba(255,255,255,.12);
    border: none; color: #fff;
    width: 52px; height: 52px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    transition: background var(--transition);
    z-index: 2;
  }

  .lb__nav:hover { background: rgba(255,255,255,.25); }
  .lb__nav--prev { left: 1rem; }
  .lb__nav--next { right: 1rem; }

  @media (max-width: 1100px) { .gallery__mosaic { grid-template-columns: repeat(4, 1fr); grid-auto-rows: 200px; } }
  @media (max-width: 820px)  { .gallery__mosaic { grid-template-columns: repeat(3, 1fr); grid-auto-rows: 180px; } }
  @media (max-width: 560px)  {
    .gallery__mosaic { grid-template-columns: repeat(2, 1fr); grid-auto-rows: 155px; gap: .5rem; }
    .gallery__tile--featured { grid-column: span 2; grid-row: span 1; }
    .lb__nav--prev { left: .4rem; width: 40px; height: 40px; }
    .lb__nav--next { right: .4rem; width: 40px; height: 40px; }
  }
</style>

<script>
  interface GItem { src: string; alt: string; category: string; }
  const allItems: GItem[] = [];

  const grid  = document.getElementById('galleryGrid')!;
  const tiles = Array.from(grid.querySelectorAll<HTMLElement>('.gallery__tile'));
  tiles.forEach(t => allItems.push({ src: t.dataset.src!, alt: t.dataset.alt!, category: t.dataset.category! }));

  // pagination
  const itemsPerPage = 12;
  let currentPage = 1;
  const totalPages = Math.ceil(allItems.length / itemsPerPage);

  const pagePrev = document.getElementById('pagePrev')! as HTMLButtonElement;
  const pageNext = document.getElementById('pageNext')! as HTMLButtonElement;
  const pageNumbers = document.getElementById('pageNumbers')!;

  function updatePagination() {
    pagePrev.disabled = currentPage === 1;
    pageNext.disabled = currentPage === totalPages;
    pageNumbers.innerHTML = '';
    for (let p = 1; p <= totalPages; p++) {
      const btn = document.createElement('button');
      btn.textContent = String(p);
      btn.className = 'gallery__page-num' + (p === currentPage ? ' is-active' : '');
      btn.addEventListener('click', () => showPage(p));
      pageNumbers.appendChild(btn);
    }
  }

  function showPage(page: number) {
    currentPage = Math.min(Math.max(1, page), totalPages);
    const start = (currentPage - 1) * itemsPerPage;
    const end = start + itemsPerPage;
    tiles.forEach((t, idx) => {
      const i = parseInt(t.dataset.index!);
      const visible = i >= start && i < end;
      t.classList.toggle('is-hidden', !visible);
      t.classList.remove('gallery__tile--featured');
    });
    const first = tiles.find(t => !t.classList.contains('is-hidden'));
    if (first) first.classList.add('gallery__tile--featured');
    updatePagination();
  }

  function visible(): GItem[] {
    const start = (currentPage - 1) * itemsPerPage;
    return allItems.slice(start, start + itemsPerPage);
  }

  pagePrev.addEventListener('click', () => showPage(currentPage - 1));
  pageNext.addEventListener('click', () => showPage(currentPage + 1));

  showPage(1);

  // WhatsApp cotizar
  function cotizarWA(src: string, alt: string) {
    const imgUrl = window.location.origin + (src.startsWith('/') ? src : '/' + src);
    const msg = `Hola! Vi este arreglo en su galería y me gustaría cotizarlo 🌸\n\nArreglo: *${alt}*\nImagen: ${imgUrl}`;
    window.open(`https://wa.me/5212371113802?text=${encodeURIComponent(msg)}`, '_blank', 'noopener,noreferrer');
  }

  grid.querySelectorAll<HTMLButtonElement>('.gallery__tile-cta').forEach(btn => {
    btn.addEventListener('click', e => { e.stopPropagation(); cotizarWA(btn.dataset.src!, btn.dataset.alt!); });
  });

  // Lightbox
  const lb       = document.getElementById('lightbox')!;
  const lbImg    = document.getElementById('lbImg') as HTMLImageElement;
  const lbCap    = document.getElementById('lbCaption')!;
  const lbCnt    = document.getElementById('lbCounter')!;
  const lbClose  = document.getElementById('lbClose')!;
  const lbPrev   = document.getElementById('lbPrev')!;
  const lbNext   = document.getElementById('lbNext')!;
  const lbCotizar= document.getElementById('lbCotizar')!;
  let currentIdx = 0;


  function renderLb() {
    const item = visible()[currentIdx];
    lbImg.src = item.src; lbImg.alt = item.alt;
    lbCap.textContent = item.alt;
    lbCnt.textContent = `${currentIdx + 1} / ${visible().length}`;
  }

  function openLb(idx: number) { currentIdx = idx; renderLb(); lb.hidden = false; document.body.style.overflow = 'hidden'; lbClose.focus(); }
  function closeLb() { lb.hidden = true; document.body.style.overflow = ''; }

  function nav(dir: 1 | -1) {
    const v = visible();
    currentIdx = (currentIdx + dir + v.length) % v.length;
    lbImg.style.cssText = 'opacity:0;transform:scale(.95);transition:opacity .1s,transform .1s';
    setTimeout(() => { renderLb(); lbImg.style.cssText = 'opacity:1;transform:scale(1);transition:opacity .15s,transform .15s'; }, 115);
  }

  tiles.forEach(tile => {
    tile.addEventListener('click', e => {
      if ((e.target as HTMLElement).closest('.gallery__tile-cta')) return;
      const idx = visible().findIndex(i => i.src === tile.dataset.src);
      if (idx !== -1) openLb(idx);
    });
    tile.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); tile.click(); } });
  });

  lbClose.addEventListener('click', closeLb);
  lbPrev.addEventListener('click', () => nav(-1));
  lbNext.addEventListener('click', () => nav(1));
  lb.addEventListener('click', e => { if (e.target === lb) closeLb(); });
  lbCotizar.addEventListener('click', () => { const item = visible()[currentIdx]; cotizarWA(item.src, item.alt); });

  document.addEventListener('keydown', e => {
    if (lb.hidden) return;
    if (e.key === 'Escape') closeLb();
    if (e.key === 'ArrowLeft') nav(-1);
    if (e.key === 'ArrowRight') nav(1);
  });

  let touchStart = 0;
  lb.addEventListener('touchstart', e => { touchStart = e.touches[0].clientX; }, { passive: true });
  lb.addEventListener('touchend', e => { const d = touchStart - e.changedTouches[0].clientX; if (Math.abs(d) > 50) nav(d > 0 ? 1 : -1); });
</script>
