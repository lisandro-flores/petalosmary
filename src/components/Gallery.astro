---
import { Image, getImage } from 'astro:assets';
import { FALLBACK_GALLERY } from '../lib/fallback';
import type { GalleryItem } from '../lib/fallback';

interface Props { items?: GalleryItem[]; }
const { items = FALLBACK_GALLERY } = Astro.props;

// Solo mostrar 6 imágenes para mantener limpio
const displayItems = items.slice(0, 6);

const optimizedItems = await Promise.all(
  displayItems.map(async (item) => {
    const optImg = await getImage({ src: item.src, format: 'webp', width: 1200 });
    return { ...item, optimizedSrc: optImg.src };
  })
);
---

<section class="gallery" id="galeria" aria-labelledby="gallery-title">
  <div class="container">
    <header class="gallery__header reveal">
      <span class="section-label">Nuestro trabajo</span>
      <h2 class="section-title gallery__title" id="gallery-title">Cada arreglo, <em>una historia</em></h2>
      <p class="section-body gallery__subtitle">Diseños pensados en papá, con flores frescas y mucho cariño en cada pedido.</p>
    </header>

    <div class="gallery__grid">
      {optimizedItems.map((item, idx) => (
        <button
          type="button"
          class="gallery__item reveal"
          style={`transition-delay: ${idx * 100}ms;`}
          data-src={item.optimizedSrc}
          data-alt={item.alt}
          aria-label={`Ver: ${item.alt}`}
        >
          <Image
            src={item.src}
            alt={item.alt}
            width={400}
            height={500}
            loading={idx < 3 ? 'eager' : 'lazy'}
            decoding="async"
          />
          <span class="gallery__overlay">
            <span class="gallery__label">Ver</span>
          </span>
        </button>
      ))}
    </div>

    <div class="gallery__more">
      <button type="button" class="gallery__link open-gallery-btn" style="background:none; border:none; cursor:pointer; font-family:inherit;">
        Ver toda la galería
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </button>
    </div>
  </div>

  <!-- Modal de galería -->
  <div id="gallery-modal" class="gallery-modal" style="display: none;">
    <div class="gallery-modal__overlay" data-gallery-overlay></div>
    <div class="gallery-modal__content">
      <button type="button" class="gallery-modal__close" data-gallery-close>
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>
      <div class="gallery-modal__img-container">
        <div id="gallery-modal-loader" class="gallery-modal__loader">Cargando...</div>
        <img id="gallery-modal-img" src="" alt="" class="gallery-modal__image" style="opacity: 0;" />
      </div>
      <div class="gallery-modal__footer">
        <a id="gallery-modal-cta" href="" target="_blank" rel="noreferrer" class="gallery-modal__cta">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Cotizar con foto
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .gallery {
    padding: 8rem 0;
    background: var(--color-surface);
  }

  .gallery__header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .gallery__title {
    margin: 0 0 1rem;
  }

  .gallery__subtitle {
    margin-inline: auto;
    text-align: center;
  }

  .gallery__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
    align-items: center;
  }

  /* Desktop: 3 columnas con la del medio más grande */
  @media (min-width: 900px) {
    .gallery__grid {
      grid-template-columns: 1fr 1.2fr 1fr;
      align-items: center;
    }
  }

  /* Móvil: 2 columnas (mejor legibilidad) */
  @media (max-width: 640px) {
    .gallery__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
    }

    .gallery__item {
      aspect-ratio: 3/4;
      border-radius: 1rem;
    }
  }

  .gallery__item {
    position: relative;
    aspect-ratio: 4/5;
    overflow: hidden;
    border-radius: 1.5rem;
    background: var(--color-bg);
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition), box-shadow var(--transition);
    padding: 0;
    border: none;
    cursor: pointer;
    font-family: inherit;
  }

  .gallery__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .gallery__item:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
  }

  .gallery__item:hover img {
    transform: scale(1.08);
  }

  .gallery__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(28,25,26,0.6) 0%, rgba(28,25,26,0) 50%);
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-bottom: 2rem;
    opacity: 0;
    transition: opacity var(--transition);
  }

  .gallery__item:hover .gallery__overlay,
  .gallery__item:focus-visible .gallery__overlay {
    opacity: 1;
  }

  .gallery__item:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 4px;
  }

  .gallery__label {
    color: #fff;
    font-size: 0.9375rem;
    font-family: var(--font-body);
    font-weight: 500;
    padding: 0.75rem 1.75rem;
    background: rgba(255,255,255,0.15);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.3);
    border-radius: 999px;
    transform: translateY(20px);
    transition: transform var(--transition);
  }

  .gallery__item:hover .gallery__label,
  .gallery__item:focus-visible .gallery__label {
    transform: translateY(0);
  }

  .gallery__more {
    text-align: center;
    margin-top: 4rem;
  }

  .gallery__link {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-text);
    font-size: 1.0625rem;
    font-weight: 500;
    text-decoration: none;
    transition: color var(--transition), transform var(--transition);
  }

  .gallery__link:hover {
    color: var(--color-primary);
    transform: translateX(4px);
  }

  /* Modal Styles */
  .gallery-modal {
    position: fixed;
    inset: 0;
    z-index: 1001;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }

  .gallery-modal__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .gallery-modal__content {
    position: relative;
    z-index: 2;
    background: #fff;
    border-radius: 2rem;
    max-width: 500px;
    width: 100%;
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    animation: modalSlideUp 0.3s ease-out;
  }

  @keyframes modalSlideUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .gallery-modal__close {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background: rgba(255, 255, 255, 0.9);
    border: none;
    border-radius: 50%;
    width: 2.5rem;
    height: 2.5rem;
    font-size: 1.5rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 3;
    transition: background 0.2s;
  }

  .gallery-modal__close:hover {
    background: #fff;
  }

  .gallery-modal__img-container {
    position: relative;
    width: 100%;
    min-height: 200px;
    background: #f3f4f6;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .gallery-modal__loader {
    position: absolute;
    color: #6b7280;
    font-size: 0.875rem;
    font-weight: 500;
  }

  .gallery-modal__image {
    width: 100%;
    max-height: 50vh;
    height: auto;
    object-fit: contain;
    display: block;
    flex-shrink: 0;
    transition: opacity 0.3s ease;
    position: relative;
    z-index: 2;
  }

  .gallery-modal__footer {
    padding: 2rem;
    text-align: center;
    overflow-y: auto;
    flex-grow: 1;
  }

  .gallery-modal__alt {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 1.5rem;
    line-height: 1.5;
  }

  .gallery-modal__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: #1e3a8a;
    color: #fff;
    padding: 0.875rem 2rem;
    border-radius: 999px;
    font-weight: 600;
    text-decoration: none;
    transition: transform var(--transition), box-shadow var(--transition), background var(--transition);
    box-shadow: 0 8px 24px rgba(30, 58, 138, 0.25);
  }

  .gallery-modal__cta:hover {
    transform: translateY(-2px);
    background: #1e40af;
    box-shadow: 0 12px 32px rgba(30, 58, 138, 0.35);
  }

  @media (max-width: 640px) {
    .gallery {
      padding: 5rem 0;
    }

    .gallery-modal__content {
      max-width: 90vw;
      border-radius: 1.5rem;
    }

    .gallery-modal__footer {
      padding: 1.5rem;
    }

    .gallery-modal__alt {
      font-size: 1rem;
    }
  }
</style>

<script>
  const galleryModal = document.getElementById('gallery-modal') as HTMLDivElement | null;
  const galleryModalImg = document.getElementById('gallery-modal-img') as HTMLImageElement | null;
  const galleryModalCta = document.getElementById('gallery-modal-cta') as HTMLAnchorElement | null;

  function openGalleryModal(src: string, alt: string) {
    if (!galleryModal || !galleryModalImg || !galleryModalCta) return;

    // Reset image to show loader
    galleryModalImg.style.opacity = '0';
    
    // When image loads, show it
    galleryModalImg.onload = () => {
      galleryModalImg.style.opacity = '1';
    };

    galleryModalImg.src = src;
    galleryModalImg.alt = alt;

    const imgUrl = window.location.origin + (src.startsWith('/') ? src : '/' + src);
    const whatsappText = `Hola, me interesa este arreglo.\n\nImagen: ${imgUrl}`;
    galleryModalCta.href = `https://wa.me/5212371113802?text=${encodeURIComponent(whatsappText)}`;

    galleryModal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }

  function closeGalleryModal() {
    if (!galleryModal) return;
    galleryModal.style.display = 'none';
    document.body.style.overflow = 'auto';
  }

  document.querySelectorAll<HTMLElement>('.gallery__item').forEach((button) => {
    button.addEventListener('click', () => {
      const src = button.dataset.src;
      const alt = button.dataset.alt;
      if (src && alt) openGalleryModal(src, alt);
    });
  });

  document.querySelectorAll<HTMLElement>('[data-gallery-close]').forEach((button) => {
    button.addEventListener('click', closeGalleryModal);
  });

  const galleryModalOverlay = document.querySelector<HTMLElement>('[data-gallery-overlay]');
  galleryModalOverlay?.addEventListener('click', closeGalleryModal);

  // Cerrar modal al presionar ESC
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeGalleryModal();
    }
  });
</script>
