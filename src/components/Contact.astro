        </svg>
        Reservar por WhatsApp
      </a>

      <p class="contact__hours">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        Lun – Sáb: 9am – 7pm &nbsp;|&nbsp; Dom: 10am – 3pm
      </p>
    </div>
  </div>
</section>

<style>
  .contact {
    padding: 7rem 0 8rem;
    background: linear-gradient(160deg, #4a044e 0%, #7c1d5f 40%, #be185d 100%);
    position: relative;
    overflow: hidden;
  }

  .contact__texture {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.04'/%3E%3C/svg%3E");
    opacity: 0.5;
    pointer-events: none;
    z-index: 0;
  }

  /* Floating petals */
  .contact__petals {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .contact__petals span {
    position: absolute;
    font-size: clamp(1.2rem, 2.5vw, 2.5rem);
    color: rgba(255, 255, 255, 0.06);
    animation: petalFloat 8s ease-in-out infinite;
  }

  .contact__petals span:nth-child(1)  { top:  8%; left:  8%; animation-delay: 0s;   }
  .contact__petals span:nth-child(2)  { top: 18%; right:10%; animation-delay: .8s;  }
  .contact__petals span:nth-child(3)  { top: 55%; left: 5%; animation-delay: 1.6s; }
  .contact__petals span:nth-child(4)  { top: 70%; right:8%; animation-delay: .4s;  }
  .contact__petals span:nth-child(5)  { top: 85%; left:40%; animation-delay: 2.2s; }
  .contact__petals span:nth-child(6)  { top: 35%; right:18%; animation-delay: 1.1s; }
  .contact__petals span:nth-child(7)  { top: 25%; left: 60%; animation-delay: 2.8s; }

  @keyframes petalFloat {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50%       { transform: translateY(-20px) rotate(12deg); }
  }

  .contact__inner {
    max-width: 640px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .contact__content {
    text-align: center;
  }

  .contact__preheader {
    display: inline-block;
    background: rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.9);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.45rem 1.1rem;
    border-radius: 100px;
    margin-bottom: 1.75rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(10px);
  }

  .contact__title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    font-weight: 600;
    color: #fff;
    margin: 0 0 1.5rem;
    line-height: 1.15;
  }

  .contact__title em {
    font-style: italic;
    color: #fbbdd8;
    font-weight: 500;
  }

  .contact__text {
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.8;
    margin: 0 0 2rem;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  .contact__trust {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
    margin: 2rem 0 2.5rem;
  }

  .trust-item {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.85);
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }

  .trust-item svg {
    color: #86efac;
    flex-shrink: 0;
  }

  .contact__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    background: #fff;
    color: #be185d;
    padding: 1.15rem 2.5rem;
    border-radius: 999px;
    font-size: 1.1rem;
    font-weight: 700;
    text-decoration: none;
    transition: transform var(--transition), box-shadow var(--transition);
    box-shadow: 0 12px 36px rgba(0, 0, 0, 0.2);
    position: relative;
    overflow: hidden;
  }

  .contact__cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(190, 24, 93, 0.04), transparent);
    border-radius: inherit;
  }

  .contact__cta:hover {
    transform: translateY(-3px) scale(1.03);
    box-shadow: 0 18px 48px rgba(0, 0, 0, 0.25);
  }

  .contact__cta:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 4px;
  }

  .contact__hours {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.5);
    margin: 2rem 0 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
  }

  .contact__hours svg {
    flex-shrink: 0;
  }

  @media (max-width: 600px) {
    .contact {
      padding: 5rem 0 6rem;
    }

    .contact__title {
      font-size: 1.85rem;
    }

    .contact__text {
      font-size: 0.95rem;
    }

    .contact__trust {
      gap: 1rem;
      flex-direction: column;
      align-items: center;
    }

    .contact__cta {
      padding: 1rem 2rem;
      font-size: 1rem;
    }
  }
</style>
