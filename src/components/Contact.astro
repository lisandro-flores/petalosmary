    <span><svg width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22c4.97 0 9-4.03 9-9-4.97 0-9-4.03-9-9 0 4.97-4.03 9-9 9 4.97 0 9 4.03 9 9z"/></svg></span>
    <span><svg width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="m12 3-1.9 5.8a2 2 0 0 1-1.3 1.3L3 12l5.8 1.9a2 2 0 0 1 1.3 1.3L12 21l1.9-5.8a2 2 0 0 1 1.3-1.3L21 12l-5.8-1.9a2 2 0 0 1-1.3-1.3L12 3Z"/></svg></span>
    <span><svg width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22c4.97 0 9-4.03 9-9-4.97 0-9-4.03-9-9 0 4.97-4.03 9-9 9 4.97 0 9 4.03 9 9z"/></svg></span>
    <span><svg width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="m12 3-1.9 5.8a2 2 0 0 1-1.3 1.3L3 12l5.8 1.9a2 2 0 0 1 1.3 1.3L12 21l1.9-5.8a2 2 0 0 1 1.3-1.3L21 12l-5.8-1.9a2 2 0 0 1-1.3-1.3L12 3Z"/></svg></span>
    <span><svg width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22c4.97 0 9-4.03 9-9-4.97 0-9-4.03-9-9 0 4.97-4.03 9-9 9 4.97 0 9 4.03 9 9z"/></svg></span>
  </div>

  <div class="container contact__inner">
    <div class="contact__content reveal">
      <span class="contact__preheader">¿Lista para tu pedido?</span>
     
      <h2 class="contact__title" id="contact-title">
        Escríbenos y diseñamos<br>
        <em>tu arreglo ideal</em>
      </h2>
      
      <p class="contact__text">
        Cuéntanos tu idea, la ocasión y tu presupuesto. 
        Te respondemos pronto con opciones personalizadas para sorprender a quien más quieres.
      </p>

      <div class="contact__trust">
        <span class="trust-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Diseños personalizados
        </span>
        <span class="trust-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Entrega garantizada
        </span>
        <span class="trust-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Atención rápida
        </span>
      </div>
      
      <a 
        href="https://wa.me/5212371113802?text=Hola%2C%20quiero%20cotizar%20un%20arreglo%20floral" 
        class="contact__cta"
        target="_blank"
        rel="noreferrer"
      >
