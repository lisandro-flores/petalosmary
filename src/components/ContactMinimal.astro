<section class="contact" id="contacto" aria-labelledby="contact-title">
  <!-- Decorative petals -->
  <div class="contact__petals" aria-hidden="true">
    <span>·</span><span>·</span><span>·</span><span>·</span>
    <span>·</span><span>·</span><span>·</span>
  </div>

  <div class="container contact__inner">
    <div class="contact__content">
      <div class="contact__preheader">Últimas horas...</div>
      
      <h2 class="contact__title" id="contact-title">
        ¿Lista para sorprender a mamá <em>este 10 de Mayo</em>?
      </h2>
      
      <p class="contact__text">
        Escríbenos por WhatsApp con tu idea, presupuesto y fecha de entrega. 
        Te respondemos en menos de 2 horas y aseguramos tu pedido.
      </p>

      <div class="contact__trust">
        <span class="trust-item">✓ Diseños personalizados</span>
        <span class="trust-item">✓ Entrega garantizada</span>
        <span class="trust-item">✓ Atención rápida</span>
      </div>
      
      <a 
        href="https://wa.me/5212371113802?text=Hola%2C%20quiero%20cotizar%20un%20arreglo%20para%20el%2010%20de%20mayo" 
        class="contact__cta"
        target="_blank"
        rel="noreferrer"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Reservar ahora por WhatsApp
      </a>

      <p class="contact__hours">
        <strong>Atención especial:</strong> Lun – Sáb: 9am – 7pm | Dom: 10am – 5pm
      </p>
    </div>
  </div>
</section>

<style>
  .contact {
    padding: 6rem 0 7rem;
    background: linear-gradient(135deg, #fce4ec 0%, #f8bbd0 50%, #f5a9c1 100%);
    position: relative;
    overflow: hidden;
  }

  /* Floating petals */
  .contact__petals {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
    opacity: 0.08;
  }

  .contact__petals span {
    position: absolute;
    font-size: clamp(1.5rem, 3vw, 3rem);
    animation: petalFloat 8s ease-in-out infinite;
  }

  .contact__petals span:nth-child(1)  { top:  5%; left:  5%; animation-delay: 0s;   }
  .contact__petals span:nth-child(2)  { top: 20%; right:8%; animation-delay: .8s;  }
  .contact__petals span:nth-child(3)  { top: 60%; left: 8%; animation-delay: 1.6s; }
  .contact__petals span:nth-child(4)  { top: 75%; right:12%; animation-delay: .4s;  }
  .contact__petals span:nth-child(5)  { top: 85%; left:35%; animation-delay: 2.2s; }
  .contact__petals span:nth-child(6)  { top: 40%; right:15%; animation-delay: 1.1s; }
  .contact__petals span:nth-child(7)  { top: 30%; left: 55%; animation-delay: 2.8s; }

  @keyframes petalFloat {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50%       { transform: translateY(-24px) rotate(15deg); }
  }

  .contact__inner {
    max-width: 600px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .contact__content {
    text-align: center;
  }

  .contact__preheader {
    display: inline-block;
    background: rgba(255, 255, 255, 0.7);
    color: #be185d;
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.5rem 1rem;
    border-radius: 100px;
    margin-bottom: 1.5rem;
    backdrop-filter: blur(10px);
    animation: fadeDown 0.8s ease-out;
  }

  .contact__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 700;
    color: #4a044e;
    margin: 0 0 1.5rem;
    line-height: 1.15;
    animation: fadeUp 0.8s ease-out 0.2s both;
  }

  .contact__title em {
    font-style: italic;
    color: #db2777;
    font-weight: 600;
    position: relative;
    display: inline-block;
  }

  .contact__title em::after {
    content: '';
    position: absolute;
    bottom: 3px;
    left: 0;
    width: 100%;
    height: 10px;
    background: rgba(252, 165, 165, 0.4);
    z-index: -1;
    border-radius: 3px;
  }

  .contact__text {
    font-size: 1.05rem;
    color: #831843;
    line-height: 1.8;
    margin: 0 0 2rem;
    max-width: 520px;
    margin-left: auto;
    margin-right: auto;
    animation: fadeUp 0.8s ease-out 0.4s both;
  }

  .contact__trust {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
    margin: 2.5rem 0;
    animation: fadeUp 0.8s ease-out 0.5s both;
  }

  .trust-item {
    font-size: 0.95rem;
    color: #6b1d47;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .contact__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    background: #be185d;
    color: #fff;
    padding: 1.25rem 2.5rem;
    border-radius: 999px;
    font-size: 1.1rem;
    font-weight: 700;
    text-decoration: none;
    transition: transform var(--transition), box-shadow var(--transition), background var(--transition);
    box-shadow: 0 12px 32px rgba(190, 24, 93, 0.3);
    animation: fadeUp 0.8s ease-out 0.6s both;
  }

  .contact__cta:hover {
    transform: translateY(-4px);
    background: #9d174d;
    box-shadow: 0 16px 40px rgba(190, 24, 93, 0.4);
  }

  .contact__cta:focus-visible {
    outline: 2px solid #db2777;
    outline-offset: 4px;
  }

  .contact__hours {
    font-size: 0.9rem;
    color: #6b1d47;
    margin: 2rem 0 0;
    animation: fadeUp 0.8s ease-out 0.7s both;
  }

  .contact__hours strong {
    color: #be185d;
    font-weight: 700;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeDown {
    from { opacity: 0; transform: translateY(-15px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 600px) {
    .contact {
      padding: 4rem 0 5rem;
    }

    .contact__title {
      font-size: 1.75rem;
    }

    .contact__text {
      font-size: 1rem;
    }

    .contact__trust {
      gap: 1rem;
      flex-direction: column;
      align-items: center;
    }

    .contact__cta {
      padding: 1rem 2rem;
      font-size: 1rem;
    }
  }
</style>
