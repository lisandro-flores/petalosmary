---
import { Image } from 'astro:assets';
import logoImg from '../assets/logo.png';
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__top">
    <div class="container footer__top-inner">
      <div class="footer__brand-col">
       
        <p class="footer__tagline">Florería en San José Buenavista, Puebla.</p>
        <a
          href="https://wa.me/5212371113802"
          class="footer__wa-btn"
          target="_blank"
          rel="noreferrer"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Escribir por WhatsApp
        </a>
      </div>

      <div class="footer__links-col">
        <p class="footer__col-title">Navegación</p>
        <nav aria-label="Navegación del footer">
          <a href="#inicio">Inicio</a>
          <a href="#galeria">Galería</a>
          <a href="#contacto">Contacto</a>
        </nav>
      </div>

      <div class="footer__hours-col">
        <p class="footer__col-title">Horario de atención</p>
        <ul>
          <li>Lun – Sáb: 9:00 am – 7:00 pm</li>
          <li>Domingo: 10:00 am – 3:00 pm</li>
          <li>Festivos especiales: horario ampliado</li>
        </ul>
        <p class="footer__phone">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.63A2 2 0 012 0h3a2 2 0 012 1 12 12 0 00.57 2.57 2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.86.23 1.72.38 2.57.57A2 2 0 0122 14.66v.26z"/></svg>
          +52 237 111 3802
        </p>
      </div>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p class="footer__copy">© {year} Pétalos Mary — Todos los derechos reservados</p>
      <p class="footer__made">Florería artesanal con amor</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #1c191a;
    color: #fff;
  }

  .footer__top {
    padding: 4rem 0 3rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .footer__top-inner {
    display: grid;
    grid-template-columns: 2fr 1fr 1.5fr;
    gap: 3rem;
    align-items: start;
  }

  .footer__logo-img {
    height: 40px;
    width: auto;
    display: block;
    margin-bottom: 1rem;
    filter: brightness(0) invert(1); /* Hack para hacerlo blanco si el logo original tiene colores oscuros, opcional */
  }

  .footer__tagline {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.6;
    margin: 0 0 1.5rem;
    max-width: 26ch;
  }

  .footer__wa-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.15);
    padding: 0.65rem 1.25rem;
    border-radius: 999px;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    transition: background 0.25s ease, border-color 0.25s ease;
  }

  .footer__wa-btn:hover {
    background: rgba(255, 255, 255, 0.14);
    border-color: rgba(255, 255, 255, 0.3);
  }

  .footer__col-title {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
    margin: 0 0 1rem;
  }

  .footer__links-col nav {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer__links-col nav a {
    color: rgba(255, 255, 255, 0.65);
    font-size: 0.9rem;
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer__links-col nav a:hover {
    color: #fff;
  }

  .footer__hours-col ul {
    list-style: none;
    padding: 0;
    margin: 0 0 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .footer__hours-col li {
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.875rem;
    line-height: 1.5;
  }

  .footer__phone {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.85rem;
    margin: 0;
  }

  .footer__bottom {
    padding: 1.5rem 0;
  }

  .footer__bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer__copy {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.3);
    margin: 0;
  }

  .footer__made {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.25);
    margin: 0;
    font-style: italic;
  }

  @media (max-width: 768px) {
    .footer__top-inner {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .footer__brand-col {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 480px) {
    .footer__top-inner {
      grid-template-columns: 1fr;
    }

    .footer__bottom-inner {
      justify-content: center;
      text-align: center;
      flex-direction: column;
      gap: 0.25rem;
    }
  }
</style>
