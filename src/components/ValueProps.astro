---
const items = [
  {
    title: 'Atención cercana',
    body: 'Acompañamiento directo por WhatsApp para resolver dudas, cotizar y confirmar cada detalle.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
  },
  {
    title: 'Diseños a medida',
    body: 'Ramos, arreglos y detalles florales pensados para la ocasión, el presupuesto y el estilo de cada cliente.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  },
  {
    title: 'Entrega local',
    body: 'Coordinación práctica para entregas en San José Buenavista, San Marcos Tlacoyalco y zonas cercanas.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
  },
  {
    title: 'Especial Día del Padre',
    body: 'Ramos, arreglos florales y detalles masculinos pensados especialmente para festejar a papá en su día.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
  },
];
---

<section class="value-props section" aria-labelledby="value-props-title">
  <div class="container">
    <div class="value-props__header reveal">
      <span class="section-label">Por qué elegirnos</span>
      <h2 class="section-title" id="value-props-title">Flores con <em>atención personalizada</em></h2>
      <p class="section-body value-props__intro">
        Cada arreglo se crafta pensando en ti, en quien lo recibe y en el momento que merece celebrarse.
      </p>
    </div>

    <div class="value-props__grid">
      {items.map((item, index) => (
        <article class="value-props__card reveal" style={`transition-delay: ${index * 100}ms;`}>
          <div class="value-props__icon-wrap">
            <span class="value-props__icon" set:html={item.icon} />
          </div>
          <h3 class="value-props__title">{item.title}</h3>
          <p class="value-props__body">{item.body}</p>
          <div class="value-props__card-accent" aria-hidden="true"></div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .value-props {
    padding-top: 2rem;
    padding-bottom: 3rem;
  }

  .value-props__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .value-props__intro {
    margin-inline: auto;
    margin-top: .9rem;
  }

  .value-props__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .value-props__card {
    background: rgba(255,255,255,.9);
    border: 1px solid rgba(239, 232, 235, 0.8);
    border-radius: 20px;
    padding: 1.75rem 1.5rem;
    box-shadow: 0 4px 12px rgba(28, 25, 26, 0.03);
    transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
    position: relative;
    overflow: hidden;
  }

  .value-props__card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(30, 58, 138, 0.08);
    border-color: rgba(30, 58, 138, 0.15);
  }

  .value-props__card-accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--color-primary), #3b82f6);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
    border-radius: 0 0 2px 2px;
  }

  .value-props__card:hover .value-props__card-accent {
    transform: scaleX(1);
  }

  .value-props__icon-wrap {
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 14px;
    background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
    color: var(--color-primary);
    margin-bottom: 1.1rem;
    transition: transform var(--transition), background var(--transition);
  }

  .value-props__card:hover .value-props__icon-wrap {
    transform: scale(1.08);
    background: linear-gradient(135deg, #e0f2fe 0%, #bae6fd 100%);
  }

  .value-props__title {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: .6rem;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }

  .value-props__body {
    font-size: .9rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  @media (max-width: 900px) {
    .value-props__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .value-props {
      padding-top: 0;
    }

    .value-props__grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .value-props__card {
      padding: 1.5rem 1.25rem;
    }
  }
</style>